generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  user
  admin
}

enum TokenType {
  ACCESS
  REFRESH
  RESET_PASSWORD
  VERIFY_EMAIL
}

model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  password        String
  role            Role     @default(user)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tokens       Token[]
  applications Application[]

  @@map("users")
}

model Token {
  id          String    @id @default(uuid())
  token       String
  userId      String
  type        TokenType
  expires     DateTime
  blacklisted Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("tokens")
}

// IDP Application Models


enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PackageType {
  DIGITAL_ONLY
  PRINT_DIGITAL
}

enum ValidityYears {
  ONE
  TWO
  THREE
}

enum ApplicationStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  UNDER_REVIEW
  APPROVED
  REJECTED
  ISSUED
  SHIPPED
  COMPLETED
}

enum DocumentType {
  PASSPORT_PHOTO
  LICENSE_FRONT
  LICENSE_BACK
  SIGNATURE
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum LicenseClass {
  A // Motorcycle
  B // Car
  C // Truck
  D // Bus
  E // Trailer
}

model Application {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Progress tracking — drives "resume where you left off"
  currentStep Int               @default(1)
  status      ApplicationStatus @default(DRAFT)

  // Step 1 — Personal / Driver Info
  firstName         String?
  lastName          String?
  phone             String?
  countryOfBirth    String?
  residenceCountry  String?
  dob               DateTime?
  gender            Gender?
  licenseClasses    LicenseClass[]

  // Step 3 — Package Selection
  packageType   PackageType?
  validityYears ValidityYears?
  price         Decimal?       @db.Decimal(10, 2)

  // Shipping address — only required when packageType = PRINT_DIGITAL
  shippingLine1      String?
  shippingLine2      String?
  shippingCity       String?
  shippingState      String?
  shippingPostalCode String?
  shippingCountry    String?

  // Admin review
  reviewedBy String?
  reviewedAt DateTime?
  rejectionReason String?

  // Relations
  documents Document[]
  payment   Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("applications")
}

model Document {
  id            String       @id @default(uuid())
  applicationId String
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  type      DocumentType
  url       String
  publicId  String // cloud storage identifier, used for deletion/replacement

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([applicationId, type]) // one document of each type per application (re-upload replaces it)
  @@map("documents")
}

model Plan {
  id            String        @id @default(uuid())
  packageType   PackageType
  validityYears ValidityYears
  price         Decimal       @db.Decimal(10, 2)
  isActive      Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([packageType, validityYears])
  @@map("plans")
}

model Payment {
  id            String      @id @default(uuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  stripePaymentIntentId String        @unique
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("usd")
  status                PaymentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}